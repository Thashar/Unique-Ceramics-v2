generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── NextAuth.js v5 required models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  orders   Order[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Sklep ────────────────────────────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  userId       String?
  status       OrderStatus @default(PENDING)
  total        Float
  shippingCost Float       @default(18)

  firstName String
  lastName  String
  email     String
  phone     String?
  street    String
  city      String
  postcode  String
  country   String @default("PL")
  note      String?

  paymentMethod String @default("transfer")
  paymentStatus String @default("pending")

  shippingMethod   String  @default("courier")   // courier | parcel_locker | pickup
  parcelLockerCode String?
  trackingNumber   String?
  trackingCarrier  String?                        // DPD | DHL | InPost | PocztaPolska

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  price     Float
  quantity  Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  images      String[]
  category    String   @default("inne")
  stock       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, featured])
  @@index([active, category])
  @@index([active, stock])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── Zamówienia indywidualne ──────────────────────────────────────────────────

model CustomOrder {
  id            String            @id @default(cuid())
  customerName  String
  customerEmail String
  customerPhone String?
  orderType     String
  description   String
  deadline      String?
  budget        String?
  status        CustomOrderStatus @default(NEW)
  adminNotes    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum CustomOrderStatus {
  NEW
  IN_REVIEW
  DONE
  CANCELLED
}

// ─── Portfolio (Moje projekty) ────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @default("") @db.Text
  images      String[]
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, order])
}

// ─── Kategorie produktów ─────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Ustawienia sklepu ────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
